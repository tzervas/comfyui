# OpenWebUI / Pipelines shared configuration
#
# NOTE:
# - These are safe defaults/placeholders.
# - Secrets should live in .env.homelab or Docker secrets (see TODOs).

# --- Core endpoints (dual-host) ---
# Default to same-compose service discovery.
# In dual-host mode, override these in your deployment env file (e.g. .env.homelab)
# to point at the desktop GPU worker (e.g. http://192.168.1.99:11434).
OLLAMA_BASE_URL=http://ollama:11434
COMFYUI_BASE_URL=http://comfyui:18188

# Public URLs (what the browser should fetch for media playback).
# If you access ComfyUI via nginx at https://<stack>/comfyui/, set COMFYUI_PUBLIC_BASE_URL accordingly.
# TODO: Set these to your real FQDN/ports for correct inline playback URLs.
# TODO: Set these to your real FQDN/ports for correct inline playback URLs.
OPENWEBUI_PUBLIC_BASE_URL=https://homelab.lan/
COMFYUI_PUBLIC_BASE_URL=https://homelab.lan/comfyui/

# --- OpenWebUI feature toggles (best-effort; some are UI settings) ---
ENABLE_IMAGE_GENERATION=True
ENABLE_VOICE=True

# --- Pipelines ---
PIPELINES_API_KEY=0p3n-w3bu!

# --- ComfyUI workflow templates for tools ---
# These are placeholders; swap in real WAN/AnimateDiff/ACE-Step workflows.
# TODO: Add/point to actual video/audio workflow JSON exports (API format).
COMFYUI_WORKFLOW_IMAGE=/app/assets/comfyui/workflows/default_workflow.json
COMFYUI_WORKFLOW_VIDEO=/app/assets/comfyui/workflows/video_workflow_api.json
COMFYUI_WORKFLOW_AUDIO=/app/assets/comfyui/workflows/audio_workflow_api.json

# Polling/timing
COMFYUI_POLL_SECONDS=2
COMFYUI_TIMEOUT_SECONDS=900

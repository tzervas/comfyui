# Model Vault Dockerfile
FROM rust:latest as builder

WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY src ./src

RUN cargo build --release

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    sqlite3 \
    libsqlite3-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app/target/release/model-vault /app/model-vault
COPY config ./config

# Create storage directory
RUN mkdir -p /var/lib/model-vault

EXPOSE 8080

CMD ["./model-vault", "serve"]
FROM python:3.12-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Pre-install Python packages including latest LangChain and LangGraph
RUN pip install --no-cache-dir \
    fastapi \
    uvicorn \
    gunicorn \
    requests \
    langchain==0.3.7 \
    langgraph==0.2.45 \
    langchain-ollama==0.2.0

# Set working directory
WORKDIR /app

# Copy application
COPY langchain_app.py .

# Expose port
EXPOSE 8000

# Run the application with Gunicorn for better performance
CMD ["gunicorn", "langchain_app:app", "-w", "4", "-k", "uvicorn.workers.UvicornWorker", "--bind", "0.0.0.0:8000"]
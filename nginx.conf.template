events {
    worker_connections 1024;
}

http {
    # Docker embedded DNS (dynamic service discovery). This prevents stale
    # upstream IPs when containers are recreated. K8s will use kube-dns/coredns.
    resolver 127.0.0.11 valid=10s;
    resolver_timeout 2s;

    # SSL configuration
    ssl_certificate /etc/ssl/certs/localhost/cert.pem;
    ssl_certificate_key /etc/ssl/certs/localhost/key.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Optional mTLS (client cert auth)
    # - Set MTLS_VERIFY=off|optional|on
    # - If using mTLS, mount CA at /etc/ssl/certs/localhost/ca.pem
    ${MTLS_CA_DIRECTIVE}
    ssl_verify_client ${MTLS_VERIFY};
    ssl_verify_depth 2;

    # Upstreams (service discovery via Docker DNS / K8s Service DNS)
    # All services use internal container names; Docker/K8s DNS resolves these
    upstream ollama_backend {
        zone ollama_backend 64k;
        server ${OLLAMA_UPSTREAM} resolve;
        keepalive 32;
    }

    upstream comfyui_backend {
        zone comfyui_backend 64k;
        server ${COMFYUI_UPSTREAM} resolve;
        keepalive 32;
    }

    upstream code_executor_backend {
        zone code_executor_backend 64k;
        server code_executor:5000 resolve;
        keepalive 16;
    }

    upstream langchain_backend {
        zone langchain_backend 64k;
        server langchain:8000 resolve;
        keepalive 32;
    }

    upstream langflow_backend {
        zone langflow_backend 64k;
        server langflow:7860 resolve;
        keepalive 32;
    }

    upstream model_vault_backend {
        zone model_vault_backend 64k;
        server model-vault:8080 resolve;
        keepalive 16;
    }

    upstream openwebui_backend {
        zone openwebui_backend 64k;
        server ${OPENWEBUI_UPSTREAM} resolve;
        keepalive 32;
    }

    upstream pipelines_backend {
        zone pipelines_backend 64k;
        server ${PIPELINES_UPSTREAM} resolve;
        keepalive 16;
    }

    # Keycloak upstream for SSO
    upstream keycloak_backend {
        zone keycloak_backend 64k;
        server keycloak:8080 resolve;
        keepalive 16;
    }

    # Gzip compression
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;

    server {
        listen 80;
        server_name _ homelab.lan;

        # Unauthenticated liveness endpoint (used by container healthchecks)
        location = /healthz {
            add_header Content-Type text/plain;
            return 200 "ok\n";
        }

        # Keycloak IdP commented out until SSO is enabled
        # location /keycloak/ {
        #     proxy_pass http://keycloak_backend;
        #     proxy_set_header Host $host;
        #     proxy_set_header X-Real-IP $remote_addr;
        #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        #     proxy_set_header X-Forwarded-Proto $scheme;
        # }

        # OpenWebUI is the primary multimodal chat UI
        location / {
            proxy_pass http://openwebui_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        # Explicit compatibility alias
        location /openwebui/ {
            return 302 /;
        }

        ${SSO_LOCATIONS}

        # Ollama API proxy
        location /ollama/ {
            proxy_pass http://ollama_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            ${AUTH_GATE}
        }

        # ComfyUI UI proxy with websocket support
        location /comfyui/ {
            proxy_pass http://comfyui_backend/;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            # ai-dock service portal may emit absolute redirects to localhost:1111.
            # Rewrite them so clients stay on the nginx /comfyui/ path.
            proxy_redirect http://localhost:1111/ /comfyui/;
            proxy_redirect https://localhost:1111/ /comfyui/;
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        # LangChain API proxy
        # /langchain/ is JSON; send browsers to the Swagger UI
        location = /langchain/ {
            return 302 /langchain/docs;
        }

        location /langchain/ {
            proxy_pass http://langchain_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_connect_timeout 90s;
            proxy_send_timeout 300s;
            proxy_read_timeout 300s;
            ${AUTH_GATE}
        }

        # LangFlow UI proxy
        # LangFlow serves absolute /assets/* and /favicon.ico; rewrite HTML so it works under /langflow/.
        location = /langflow/ {
            proxy_pass http://langflow_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Prefix /langflow;
            sub_filter_types text/html;
            sub_filter_once off;
            sub_filter 'src="/assets/' 'src="/langflow/assets/';
            sub_filter 'href="/assets/' 'href="/langflow/assets/';
            sub_filter 'href="/favicon.ico"' 'href="/langflow/favicon.ico"';
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        location /langflow/assets/ {
            proxy_pass http://langflow_backend/assets/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Prefix /langflow;
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        location = /langflow/favicon.ico {
            proxy_pass http://langflow_backend/favicon.ico;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Prefix /langflow;
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        location /langflow/ {
            proxy_pass http://langflow_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Prefix /langflow;
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        # Code Executor API proxy
        # /code-executor/ is JSON; send browsers to the Swagger UI
        location = /code-executor/ {
            return 302 /code-executor/docs;
        }

        location /code-executor/ {
            proxy_pass http://code_executor_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_connect_timeout 30s;
            proxy_send_timeout 60s;
            proxy_read_timeout 60s;
            ${AUTH_GATE}
        }

        # Pipelines API (optional; primarily used for debugging/admin connectivity)
        location /pipelines/ {
            proxy_pass http://pipelines_backend/;
            # Pipelines uses Authorization: Bearer <token>. Since nginx Basic Auth also
            # uses the Authorization header, allow callers to provide the upstream
            # token via X-Pipelines-Authorization.
            proxy_set_header Authorization $http_x_pipelines_authorization;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_connect_timeout 30s;
            proxy_send_timeout 300s;
            proxy_read_timeout 300s;
            ${AUTH_GATE}
        }

        # Model Vault API (protected)
        location /model-vault/ {
            proxy_pass ${MODEL_VAULT_API_PROXY_PASS};
            ${MODEL_VAULT_PROXY_SSL}
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            ${AUTH_GATE}
        }

        # Registry APIs (worker registration/discovery)
        location /register {
            if ($http_x_registry_secret != "${REGISTRY_SECRET}") { return 403; }
            proxy_pass ${MODEL_VAULT_REGISTER_PROXY_PASS};
            ${MODEL_VAULT_PROXY_SSL}
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        location /discover {
            if ($http_x_registry_secret != "${REGISTRY_SECRET}") { return 403; }
            proxy_pass ${MODEL_VAULT_DISCOVER_PROXY_PASS};
            ${MODEL_VAULT_PROXY_SSL}
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }

    server {
        listen 443 ssl;
        server_name ${STACK_FQDN};

        # Fix redirects to preserve client-facing port when behind Docker port mapping
        absolute_redirect off;
        port_in_redirect off;

        # Unauthenticated liveness endpoint (used by container healthchecks)
        location = /healthz {
            add_header Content-Type text/plain;
            return 200 "ok\n";
        }

        # Keycloak IdP - proxy to internal service with HTTPS headers
        location /keycloak/ {
            proxy_pass http://keycloak_backend;
            proxy_set_header Host $http_host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto https;
            proxy_set_header X-Forwarded-Host $http_host;
            proxy_buffer_size 128k;
            proxy_buffers 4 256k;
            proxy_busy_buffers_size 256k;
        }

        # OpenWebUI is the primary multimodal chat UI
        location / {
            proxy_pass http://openwebui_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        # Explicit compatibility alias
        location /openwebui/ {
            return 302 /;
        }

        ${SSO_LOCATIONS}

        # Ollama API proxy
        location /ollama/ {
            proxy_pass http://ollama_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            ${AUTH_GATE}
        }

        # ComfyUI UI proxy with websocket support
        location /comfyui/ {
            proxy_pass http://comfyui_backend/;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_redirect http://localhost:1111/ /comfyui/;
            proxy_redirect https://localhost:1111/ /comfyui/;
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        # LangChain API proxy
        # /langchain/ is JSON; send browsers to the Swagger UI
        location = /langchain/ {
            return 302 /langchain/docs;
        }

        location /langchain/ {
            proxy_pass http://langchain_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_connect_timeout 90s;
            proxy_send_timeout 300s;
            proxy_read_timeout 300s;
            ${AUTH_GATE}
        }

        # LangFlow UI proxy
        # LangFlow serves absolute /assets/* and /favicon.ico; rewrite HTML so it works under /langflow/.
        location = /langflow/ {
            proxy_pass http://langflow_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Prefix /langflow;
            sub_filter_types text/html;
            sub_filter_once off;
            sub_filter 'src="/assets/' 'src="/langflow/assets/';
            sub_filter 'href="/assets/' 'href="/langflow/assets/';
            sub_filter 'href="/favicon.ico"' 'href="/langflow/favicon.ico"';
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        location /langflow/assets/ {
            proxy_pass http://langflow_backend/assets/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Prefix /langflow;
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        location = /langflow/favicon.ico {
            proxy_pass http://langflow_backend/favicon.ico;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Prefix /langflow;
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        location /langflow/ {
            proxy_pass http://langflow_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header X-Forwarded-Prefix /langflow;
            proxy_read_timeout 86400;
            ${AUTH_GATE}
        }

        # Code Executor API proxy
        # /code-executor/ is JSON; send browsers to the Swagger UI
        location = /code-executor/ {
            return 302 /code-executor/docs;
        }

        location /code-executor/ {
            proxy_pass http://code_executor_backend/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_connect_timeout 30s;
            proxy_send_timeout 60s;
            proxy_read_timeout 60s;
            ${AUTH_GATE}
        }

        # Pipelines API (optional; primarily used for debugging/admin connectivity)
        location /pipelines/ {
            proxy_pass http://pipelines_backend/;
            # See HTTP server block for header collision rationale.
            proxy_set_header Authorization $http_x_pipelines_authorization;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_connect_timeout 30s;
            proxy_send_timeout 300s;
            proxy_read_timeout 300s;
            ${AUTH_GATE}
        }

        # Model Vault API (protected)
        location /model-vault/ {
            proxy_pass ${MODEL_VAULT_API_PROXY_PASS};
            ${MODEL_VAULT_PROXY_SSL}
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            ${AUTH_GATE}
        }

        # Registry APIs (require mTLS if enabled)
        location /register {
            ${REGISTRY_MTLS_ENFORCE}
            if ($http_x_registry_secret != "${REGISTRY_SECRET}") { return 403; }
            proxy_pass ${MODEL_VAULT_REGISTER_PROXY_PASS};
            ${MODEL_VAULT_PROXY_SSL}
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        location /discover {
            ${REGISTRY_MTLS_ENFORCE}
            if ($http_x_registry_secret != "${REGISTRY_SECRET}") { return 403; }
            proxy_pass ${MODEL_VAULT_DISCOVER_PROXY_PASS};
            ${MODEL_VAULT_PROXY_SSL}
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }
}

# Desktop / GPU worker environment template
# Copy to .env.desktop and edit values.
#
# IMPORTANT: Never commit real tokens/secrets.

# Ollama
OLLAMA_PORT=11434
OLLAMA_ORIGINS=*
OLLAMA_DEBUG=false
# Optional: comma-separated models to pre-pull
# OLLAMA_MODELS=gemma3:1b,deepseek-r1:1.5b

# ComfyUI (use semver tags; switch to digests later if needed)
COMFYUI_IMAGE=ghcr.io/ai-dock/comfyui:0.3.0-cuda
COMFYUI_PORT=8188
COMFYUI_EXTRA_ARGS=--auto-launch
HF_TOKEN=

# Registry / Model Vault integration (talks to homelab ingress)
MODEL_VAULT_TOKEN=<must-match-homelab>
REGISTRY_SECRET=<must-match-homelab>
REGISTRY_URL=https://homelab.lan:8443
# Optional: if you expose model-vault behind ingress
MODEL_VAULT_URL=

# Worker advertised endpoint (what homelab will call back to)
ADVERTISE_HOST=DESKTOP_IP
ADVERTISE_SCHEME=http

# Optional mTLS client settings for registry access (leave blank unless provisioned)
REGISTRY_MTLS_CA=
REGISTRY_MTLS_CERT=
REGISTRY_MTLS_KEY=

# GPU
# Values: nvidia | amd | cpu
GPU_DRIVER=nvidia
GPU_COUNT=all

# Homelab (control-plane) environment template
# Copy to .env.homelab and edit values.
#
# IMPORTANT: Never commit real tokens/secrets.

# LAN DNS name for ingress
STACK_FQDN=homelab.lan

# Nginx upstream targets
# In dual-host mode, point at your GPU worker.
# Example:
#   OLLAMA_UPSTREAM=192.168.1.99:11434
#   COMFYUI_UPSTREAM=192.168.1.99:18188
OLLAMA_UPSTREAM=DESKTOP_IP:11434
COMFYUI_UPSTREAM=DESKTOP_IP:18188

# Optional: mTLS for /register and /discover on HTTPS (off|optional|on)
MTLS_VERIFY=off

# Model Vault
MODEL_VAULT_PORT=8080
MODEL_VAULT_TOKEN=<set-a-strong-token>
REGISTRY_SECRET=<set-a-strong-secret>

# Nginx
NGINX_PORT=8080
NGINX_SSL_PORT=8443
HTPASSWD_FILE=./.htpasswd

# LangChain
LANGCHAIN_PORT=8000

# LangFlow
LANGFLOW_PORT=7860
LANGFLOW_CONFIG_DIR=/tmp/langflow

# Code Executor
CODE_EXECUTOR_PORT=5000

# Database (Model Vault)
# Prefer the persistent defaults baked into compose; override only if needed.
MODEL_VAULT_DATABASE__URL=sqlite:/var/lib/model-vault/model-vault.db

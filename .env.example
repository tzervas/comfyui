# Ollama Configuration
OLLAMA_PORT=11434
OLLAMA_ORIGINS=*
HTTPS_PROXY=
OLLAMA_DEBUG=false

# ComfyUI Configuration
COMFYUI_IMAGE=ghcr.io/ai-dock/comfyui:latest-cpu  # Change to latest-cuda for GPU
COMFYUI_PORT=8188
COMFYUI_EXTRA_ARGS=--auto-launch  # Additional args like --offline or --security-level strong
HF_TOKEN=your_huggingface_token_here  # For gated models; leave empty if not needed
COMFYUI_PATH=/workspace

# GPU Configuration (set GPU_DRIVER to 'nvidia' or 'amd' if available; 'cpu' for none)
GPU_DRIVER=cpu  # Set to nvidia if GPU available
GPU_COUNT=all

# Nginx Configuration
NGINX_PORT=8080
HTPASSWD_FILE=./.htpasswd  # Path to auth file; create with htpasswd tool

# LangChain Configuration
LANGCHAIN_PORT=8000

# LangFlow Configuration
LANGFLOW_PORT=7860

# Optional: Proxy timeouts or other Nginx tweaks (extend if needed)
# NGINX_CLIENT_MAX_BODY_SIZE=100M

# Quickstart Configuration
QUICKSTART_MODE=true  # Enable default workflows, flows, and user profiles

# Model Vault Configuration (Future Enhancement)
MODEL_VAULT_PORT=8080
MODEL_VAULT_TOKEN=your-secure-vault-token-here
MODEL_VAULT_URL=http://model-vault:8080
MODEL_VAULT_STORAGE_PATH=/var/lib/model-vault